{
  "name": "openads",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:migrate": "bun run --cwd packages/db db:migrate",
    "db:studio": "bun run --cwd packages/db db:studio",
    "db:push": "bun run --cwd packages/db db:push",
    "db:reset": "bun run --cwd packages/db db:reset",
    "postinstall": "bun run db:generate || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@dirstack/kodeks": "^1.2.0",
    "autosendjs": "^1.0.3",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.64.0",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@hono/node-server": "^2.0.2",
    "postcss": "^8.5.14"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.14"
}
